{
  "name": "nn2rtl-sdk",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js",
    "dev": "tsx watch main.ts",
    "pipeline": "tsx main.ts",
    "test": "vitest",
    "test:fast": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run --exclude=test/**/*.full.test.ts",
    "test:full": "vitest run",
    "coverage": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
