{
  "name": "activation-double-buffering",
  "display_name": "Activation Double Buffering",
  "complexity_rank": 3,
  "interface_signals": [
    { "name": "clk", "direction": "input", "width_bits": 1, "role": "clock" },
    { "name": "rst_n", "direction": "input", "width_bits": 1, "role": "active-low reset" },
    { "name": "valid_in", "direction": "input", "width_bits": 1, "role": "activation load stream valid" },
    { "name": "ready_in", "direction": "output", "width_bits": 1, "role": "activation load stream ready" },
    { "name": "data_in", "direction": "input", "width_expr": "input_width_bits", "role": "activation load beat" },
    { "name": "valid_out", "direction": "output", "width_bits": 1, "role": "compute output valid" },
    { "name": "data_out", "direction": "output", "width_expr": "output_width_bits", "role": "compute output beat" },
    { "name": "load_buffer_select", "direction": "output", "width_bits": 1, "role": "ping-pong buffer selected for incoming activations" },
    { "name": "compute_buffer_select", "direction": "output", "width_bits": 1, "role": "ping-pong buffer selected for compute" }
  ],
  "fit_constraints": {
    "max_bus_width_bits": 4096,
    "default_beat_width_bits": 256,
    "bram_formula": "activation BRAM bits = 2 * activation_buffer_elements * input_width_bits; weights follow the selected weight storage mode.",
    "buffer_sizing_rules": [
      "two buffers are required",
      "each buffer must hold one compute tile of activations",
      "load_buffer_select and compute_buffer_select must never target the same buffer during overlapping load/compute"
    ]
  },
  "supported_ops": ["conv2d", "maxpool"],
  "dependencies": [],
  "docs": [
    "knowledge/patterns/01_context.md",
    "knowledge/patterns/08_common_bugs.md"
  ]
}
