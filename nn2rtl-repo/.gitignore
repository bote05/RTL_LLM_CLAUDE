# Python virtualenvs
.venv/
venv/
*.egg-info/

# Runtime artifacts are pipeline-generated. Ignore output/ by default, then
# UN-IGNORE the thesis evidence (generated RTL, post-route Vivado timing/power/
# utilization reports, the layer IR, verification vectors) while keeping the
# GB-scale binaries OUT (Vivado *.dcp, golden vectors, bulk weight dumps, sim/
# tmp/worker scratch). To publish another output file add a `!output/...` line,
# then a re-exclude for any heavy types it would pull in.
output/*
!output/rtl/
!output/wrapper/
!output/resnet8/
!output/mobilenet-v2/
!output/reports/
!output/reports_integrated/
!output/power/
!output/tb/
!output/layer_ir.json
!output/golden_vectors.json
!output/pipeline_state.json
# re-exclude heavy/binary content even inside the un-ignored evidence dirs:
output/**/*.dcp
output/**/*.bin
output/**/*.vcd
output/**/*.fst
output/**/*.vvp
output/**/obj_dir*/
output/**/build_*/
output/**/weights/
output/**/goldens/
output/**/*.prek1m
output/**/*.bak
output/**/*.pre*
# compiled sim/build artifacts that live under the un-ignored reports/ dirs:
output/**/dbg_build/
output/**/verilator_*/
output/**/*.gch
output/**/*.exe
output/**/*.o
output/**/*.a
output/**/*.so
output/**/*.dll
output/**/*.tmp-*
output/**/agent_tool_use.jsonl

# Local savebacks / rollback snapshots
backups/

# Manual / one-off experiments (not part of the production pipeline)
experiments/

# Backfill helper input snapshot (contains absolute host paths)
scripts/_applied_layer_288.json

# Local comparison / smoke artifacts
comparison/
scripts/regen_add_smoke.ts
output/regression_*/
output/pass_*_stdout.log
output/*.log

