# Python virtualenvs
.venv/
venv/
*.egg-info/

# Runtime artifacts. The whole `output/` tree is generated by the pipeline
# (per-network subdirectories under `output/<network-id>/` + the legacy
# top-level layout used by resnet-50). Nothing under output/ is tracked;
# if a file under output/ ever needs to be in the repo, add an explicit
# `!output/<path>` un-ignore after this line.
output/

# Manual / one-off experiments (not part of the production pipeline)
experiments/

# Backfill helper input snapshot (contains absolute host paths)
scripts/_applied_layer_288.json

# Local comparison / smoke artifacts
comparison/
scripts/regen_add_smoke.ts
output/regression_*/
output/pass_*_stdout.log
output/*.log

# Model checkpoints
checkpoints/

# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/

# Environment
.env
.env.*

# OS
.DS_Store
Thumbs.db

# Vendored third-party data (downloaded via vendor/*/download.sh)
vendor/sky130/*.lib
contracts/**/__pycache__/

# Knowledge tiers — runtime-promoted content. Only `protected/` and tier
# `.gitkeep` markers are tracked; everything else is generated by the
# pipeline (probationary), the improve flow (improved), the doc lifecycle
# (active, archive), or the doc-lifecycle JSON itself.
knowledge/doc_lifecycle.json
knowledge/patterns/probationary/*
!knowledge/patterns/probationary/.gitkeep
knowledge/patterns/improved/*
!knowledge/patterns/improved/.gitkeep
knowledge/patterns/active/*
!knowledge/patterns/active/.gitkeep
knowledge/patterns/archive/*
!knowledge/patterns/archive/.gitkeep
knowledge/references/probationary/*
!knowledge/references/probationary/.gitkeep
knowledge/references/improved/*
!knowledge/references/improved/.gitkeep
knowledge/references/active/*
!knowledge/references/active/.gitkeep
knowledge/references/archive/*
!knowledge/references/archive/.gitkeep
