# rollback/backup snapshots anywhere in the tree (apply-script convention appends
# a backup tag AFTER the real extension, e.g. foo.v.bak_wave2 / foo.v.phase1pre /
# bar.py.predsppack). Catch every variant seen + common editor backups.
*.pre*
*.predsppack
*.pretree
*.preconv288
*.bak
*.bak_*
*.phase1pre
*.phasepre
*.orig
*.old
*~
# real-extension-then-backup-tag (e.g. *.v.<tag>, *.py.<tag>, *.mem.<tag>)
*.v.*
*.sv.*
*.vh.*
*.py.*
*.ts.*
*.mjs.*
*.cpp.*
*.mem.*
*.hex.*
*.json.*
*.checkpoint

